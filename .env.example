# ===========================================
# SocraticEngine — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# --- Application ---
APP_NAME=SocraticEngine
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Database ---
DATABASE_URL=postgresql+asyncpg://socratic:socratic_dev_pass@localhost:5432/socratic_engine
DATABASE_SYNC_URL=postgresql://socratic:socratic_dev_pass@localhost:5432/socratic_engine
DB_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# --- OpenAI (Fallback) ---
OPENAI_API_KEY=sk-xxxxx
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_HEAVY_MODEL=gpt-4o

# --- Google Gemini (Fallback) ---
GEMINI_API_KEY=AIzaSy-xxxxx
GEMINI_FAST_MODEL=gemini-2.0-flash
GEMINI_HEAVY_MODEL=gemini-2.5-pro-preview-05-06

# --- LLM Routing ---
# Primary provider for AI interventions: anthropic | openai | gemini
LLM_PRIMARY_PROVIDER=anthropic

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_AUTH_PER_MINUTE=10

# --- Encryption ---
ENCRYPTION_MASTER_KEY=change-me-to-a-32-byte-hex-string

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
